# Copy to .env and fill in. find_pump_keys.py auto-loads this file on every OS,
# so you do NOT need to "source" it (Linux) or "set" the vars (Windows) — just
# edit the values below and run the script. Real environment variables, if set,
# take precedence over what's here.

# --- MongoDB ------------------------------------------------------------------
# Choose ONE of two connection modes:
#
# (A) URI mode (Atlas / direct / no SSH): set MONGODB_URI, leave SSH_HOST empty.
# (B) SSH-tunnel + TLS mode (private MongoDB behind a bastion): set SSH_HOST
#     and the SSH_* / MONGODB_TLS_* / MONGODB_USERNAME etc. below; MONGODB_URI
#     is ignored in this mode.
MONGODB_URI="mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/?retryWrites=true&w=majority"
MONGODB_DB="solana"
MONGODB_COLLECTION="pump_keys"

# --- SSH tunnel (mode B: leave SSH_HOST empty to disable) --------------------
# When SSH_HOST is set, the script opens an SSH forward to the MongoDB host
# using public-key auth, then connects pymongo to localhost over that tunnel.
# SSH_HOST="bastion.example.com"
# SSH_PORT="22"
# SSH_USER="ubuntu"
# SSH_KEY_PATH="C:/Users/you/.ssh/id_ed25519"   # path to the PRIVATE key file
# SSH_KEY_PASSPHRASE=""                          # only if the key is encrypted
# SSH_REMOTE_MONGO_HOST="127.0.0.1"   # MongoDB host as seen FROM the bastion
# SSH_REMOTE_MONGO_PORT="27017"
# SSH_LOCAL_BIND_PORT="0"             # 0 = auto-pick a free local port

# --- TLS to MongoDB (used in mode B; for mode A put these in MONGODB_URI) ----
# Server-side verification: point at the CA that signed the MongoDB cert.
# MONGODB_TLS_CA_FILE="C:/path/to/ca.pem"
# Client-cert (mTLS) — a single PEM with the client cert + key concatenated.
# MONGODB_TLS_CERT_KEY_FILE="C:/path/to/client.pem"
# Set to "1" only for troubleshooting; do NOT leave on in production.
# MONGODB_TLS_ALLOW_INVALID_HOSTNAMES="0"
# MONGODB_TLS_ALLOW_INVALID_CERTIFICATES="0"

# --- MongoDB authentication (used in mode B) ---------------------------------
# MONGODB_USERNAME="appuser"
# MONGODB_PASSWORD="supersecret"
# MONGODB_AUTH_SOURCE="admin"
# MONGODB_AUTH_MECHANISM="SCRAM-SHA-256"   # leave blank to let pymongo auto-pick

# --- Search behavior ---------------------------------------------------------
# SUFFIX MUST match what the engine was compiled with (engine/src/config.h).
# If you change it, edit config.h and rebuild with ./build.sh
SUFFIX="pump"

# How many NEW keys to store before exiting. 0 = run until you Ctrl-C.
TARGET_COUNT="1"

# Path to the compiled engine (default points at the build output).
# VANITY_BIN="./engine/src/release/cuda_ed25519_vanity"

# Set to 1 to test the GPU + verification without touching MongoDB.
# DRY_RUN="0"

# --- GPU tuning (optional) ---------------------------------------------------
# Seeds each GPU thread tries per kernel launch. By default this is AUTO: the
# engine fills every SM and auto-tunes launch length to ~0.5s, which keeps the
# GPU busy while staying under the Windows TDR limit (driver reset if a kernel
# blocks the display GPU ~2s). Only set a value to force a FIXED size and turn
# off auto-tuning (e.g. on a headless/compute-only GPU you can push it higher).
# VANITY_ATTEMPTS_PER_THREAD=""
