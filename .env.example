# Copy to .env and fill in. find_pump_keys.py auto-loads this file on every OS,
# so you do NOT need to "source" it (Linux) or "set" the vars (Windows) — just
# edit the values below and run the script. Real environment variables, if set,
# take precedence over what's here.

# --- MongoDB (required unless DRY_RUN=1) -------------------------------------
MONGODB_URI="mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/?retryWrites=true&w=majority"
MONGODB_DB="solana"
MONGODB_COLLECTION="pump_keys"

# --- Search behavior ---------------------------------------------------------
# SUFFIX MUST match what the engine was compiled with (engine/src/config.h).
# If you change it, edit config.h and rebuild with ./build.sh
SUFFIX="pump"

# How many NEW keys to store before exiting. 0 = run until you Ctrl-C.
TARGET_COUNT="1"

# Path to the compiled engine (default points at the build output).
# VANITY_BIN="./engine/src/release/cuda_ed25519_vanity"

# Set to 1 to test the GPU + verification without touching MongoDB.
# DRY_RUN="0"
